{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "room_program",
  "title": "Room Program",
  "description": "Structured room program produced by Brief Agent",
  "type": "object",
  "required": ["project_id", "version", "building_type", "department", "jurisdiction", "rooms"],
  "properties": {
    "project_id":      { "type": "string" },
    "version":         { "type": "string" },
    "building_type":   { "type": "string", "example": "healthcare" },
    "department":      { "type": "string", "example": "geriatric_ward" },
    "jurisdiction":    { "type": "string" },
    "total_area_m2":   { "type": "number" },
    "rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "quantity", "min_area_m2"],
        "properties": {
          "id":             { "type": "string" },
          "name":           { "type": "string" },
          "quantity":       { "type": "integer" },
          "min_area_m2":    { "type": "number" },
          "preferred_area_m2": { "type": "number" },
          "room_type":      { "type": "string", "enum": ["patient_room","corridor","service","office","sanitary","circulation","plant","storage","public","other"] },
          "adjacencies":    { "type": "array", "items": { "type": "string" }, "description": "Room IDs this room should be adjacent to" },
          "must_not_adjoin":{ "type": "array", "items": { "type": "string" }, "description": "Room IDs that must NOT be adjacent" },
          "access_type":    { "type": "string", "enum": ["public","staff","restricted","service"] },
          "flow_type":      { "type": "string", "enum": ["clean","dirty","mixed","neutral"] },
          "special_requirements": { "type": "array", "items": { "type": "string" } },
          "compliance_refs":{ "type": "array", "items": { "type": "string" }, "description": "Regulation references that define requirements" }
        }
      }
    },
    "adjacency_matrix": {
      "type": "object",
      "description": "room_id → [list of room_ids it should be near]",
      "additionalProperties": { "type": "array", "items": { "type": "string" } }
    },
    "notes":        { "type": "array", "items": { "type": "string" } },
    "created_at":   { "type": "string", "format": "date-time" },
    "created_by":   { "type": "string", "default": "brief_agent" }
  }
}
