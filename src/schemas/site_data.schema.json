{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "site_data",
  "title": "Site Data",
  "description": "Normalized site input produced by Input Parser Agent",
  "type": "object",
  "required": ["project_id", "version", "source_file", "boundary", "constraints"],
  "properties": {
    "project_id":   { "type": "string" },
    "version":      { "type": "string", "example": "v1" },
    "source_file":  { "type": "string", "description": "Original filename" },
    "source_type":  { "type": "string", "enum": ["dwg","pdf","png","jpg","ifc"] },
    "scale":        { "type": "number", "description": "Drawing scale, e.g. 0.01 for 1:100" },
    "orientation":  { "type": "number", "description": "North bearing in degrees" },
    "boundary": {
      "type": "object",
      "description": "Site boundary polygon in metres",
      "required": ["points", "area_m2"],
      "properties": {
        "points":   { "type": "array", "items": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 } },
        "area_m2":  { "type": "number" }
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "setback_m":      { "type": "number", "description": "Minimum setback from boundary" },
        "max_height_m":   { "type": "number" },
        "max_floors":     { "type": "integer" },
        "access_points":  { "type": "array", "items": { "type": "array", "items": { "type": "number" }, "minItems": 2 }, "description": "Entry/exit points on boundary" },
        "existing_structures": { "type": "array", "items": { "type": "object" } },
        "notes":          { "type": "array", "items": { "type": "string" } }
      }
    },
    "jurisdiction": { "type": "string", "description": "ISO country code, e.g. SE, AE, GB" },
    "created_at":   { "type": "string", "format": "date-time" },
    "created_by":   { "type": "string", "default": "input_parser_agent" }
  }
}
