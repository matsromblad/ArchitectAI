# ArchitectAI — Environment variables
# Copy to .env and fill in your values

# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Project storage root
PROJECTS_DIR=./projects

# Compliance knowledge base root
COMPLIANCE_KB_DIR=./compliance_kb

# Dashboard WebSocket server
WS_HOST=0.0.0.0
WS_PORT=8765

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# LLM models (override defaults per agent)
# TOKEN-OPT: Use cheaper models for structured/rule-checking agents
DEFAULT_MODEL=claude-sonnet-4-6
PM_MODEL=claude-opus-4-6
BRIEF_MODEL=claude-sonnet-4-6
QA_MODEL=claude-haiku-4-5
ARCHITECT_MODEL=claude-sonnet-4-6
STRUCTURAL_MODEL=claude-sonnet-4-6
MEP_MODEL=claude-sonnet-4-6
COMPLIANCE_MODEL=claude-sonnet-4-6
IFC_MODEL=claude-haiku-4-5
COMPONENT_LIBRARY_MODEL=claude-haiku-4-5
INPUT_PARSER_MODEL=claude-sonnet-4-6
